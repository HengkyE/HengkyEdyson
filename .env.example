# Supabase (existing app)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Neon (backend only – never commit; set in Vercel Project Settings → Environment Variables)
# Get from Neon Console → Connection details (use pooled connection string)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# When set, app uses Neon API for all data (products, sales, profiles).
# Local: run backend with `npm run server` and use http://localhost:3001
# Vercel: set this to your deployment URL (e.g. https://your-project.vercel.app) in Vercel → Project Settings → Environment Variables. Never commit .env.
EXPO_PUBLIC_API_URL=http://localhost:3001

# Direct Neon Data API (no backend). When set, app talks to Neon over HTTP with JWT from Neon Auth.
# From Neon Console → Data API → enable for branch, set auth to "Use Neon Auth". Copy the API URL (e.g. https://ep-xxx.apirest.region.aws.neon.tech/neondb).
# Requires EXPO_PUBLIC_NEON_AUTH_URL and login so JWT is available. If both this and EXPO_PUBLIC_API_URL are set, Data API is used.
EXPO_PUBLIC_NEON_DATA_API_URL=

# Neon Auth (Better Auth). When set, login uses Neon Auth instead of Supabase Auth.
# From Neon Console → App Backend → Auth → Configuration (Auth URL).
EXPO_PUBLIC_NEON_AUTH_URL=https://ep-noisy-salad-a7wgbcfk.neonauth.ap-southeast-2.aws.neon.tech/neondb/auth
