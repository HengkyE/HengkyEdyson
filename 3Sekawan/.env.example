# Supabase (fallback when Neon not used)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Neon: when set, app uses Neon API for all data and Neon Auth for login.
# Use the same server as the main app: npm run server from repo root.
EXPO_PUBLIC_API_URL=http://localhost:3001
# From Neon Console → App Backend → Auth → Configuration (Auth URL)
EXPO_PUBLIC_NEON_AUTH_URL=https://ep-noisy-salad-a7wgbcfk.neonauth.ap-southeast-2.aws.neon.tech/neondb/auth

# Telegram (optional)
EXPO_PUBLIC_TELEGRAM_BOT_TOKEN=
EXPO_PUBLIC_TELEGRAM_CHAT_ID_SEKAWAN=
EXPO_PUBLIC_TELEGRAM_CHAT_ID_GROSIR=
